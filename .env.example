# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
SELF_URL=https://your-app.example.com
ALLOWED_CORS_ORIGIN=https://your-app.example.com
# Optional override; by default the API serves apps/web/dist.
CLIENT_DIST_DIR=

# PostgreSQL
DATABASE_URL=postgresql://user:password@db.example.com:5432/app_database?sslmode=require
DATABASE_MAX_CONNECTIONS=5

# Private object storage. Use these exact names; every stored key is prefixed
# with OBJECT_STORAGE_PREFIX by the app before S3-compatible API calls.
OBJECT_STORAGE_ACCESS_KEY_ID=example-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=example-secret-key
OBJECT_STORAGE_BUCKET=example-private-bucket
OBJECT_STORAGE_PREFIX=app_example/
OBJECT_STORAGE_ENDPOINT=https://example-object-storage-endpoint
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# myClawTeam auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_example-token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# myClawTeam email service
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=app_example-email-token
